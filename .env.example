# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# Database & API
DATABASE_URL=cloudflare-d1://codeempty-db
JWT_SECRET=generate-a-random-secret-here-min-32-chars
API_ENVIRONMENT=production

# Admin Initial Setup
ADMIN_EMAIL=admin@codeempty.com
ADMIN_PASSWORD_GUID=your-guid-here-or-auto-generated

# R2 Image Storage
R2_BUCKET_NAME=codeempty-images
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_SITE_NAME=CodeEmpty.com
NEXT_PUBLIC_SITE_DESCRIPTION=Personal portfolio and CMS

# Optional: Analytics & Monitoring
ANALYTICS_SCRIPT=
CLARITY_SCRIPT=

